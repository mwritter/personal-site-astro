---
const normalize = (path: string) => path.replace(/\/$/, "") || "/";

const LINKS = [
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
];

const current = normalize(Astro.url.pathname);
const page = current === "/" ? "home" : current.slice(1);

const url = Astro.url.pathname;
---

<nav class="page-nav" data-page={page}>
  <div class="links">
    <a href="/" data-active={url === "/"}>
      <img src="/invader.svg" height="20" alt="Home" />
    </a>
    {
      LINKS.map(({ href, label }) => (
        <a href={href} data-active={url === href}>
          {label}
        </a>
      ))
    }
    <div class="active-bar">
      <div class="active-thumb" transition:name="nav-thumb"></div>
    </div>
  </div>
</nav>

<style>
  .page-nav {
    padding: 20px;

    @media print {
      display: none !important;
    }
  }
  .page-nav .links {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 10ch 10ch;
    justify-content: center;
    align-content: center;
    text-align: center;
    align-items: center;
    white-space: nowrap;
    width: min-content;
    font-size: small;
  }
  .page-nav a {
    position: relative;

    &:nth-child(2) {
      border-right: 1px solid rgba(0, 0, 0, 0.1);
    }
  }
  .page-nav .active-bar {
    position: absolute;
    inset: 0;
    top: 100%;
    left: 0;
    height: 5px;
    width: 90%;
    background-color: transparent;
    border-radius: 5px;
  }
  .page-nav .active-thumb {
    position: absolute;
    inset: 0;
    left: 16px;
    background-color: var(--secondary-color);
    width: 5.5ch;
    height: 3px;
    border-radius: 5px;
    opacity: 0;
  }

  .page-nav a[data-active="true"] {
    pointer-events: none;
    color: var(--secondary-color);
  }
  .page-nav[data-page="about"] .active-thumb {
    left: 58px;
    opacity: 1;
  }
  .page-nav[data-page="blog"] .active-thumb {
    left: 135px;
    opacity: 1;
  }

  .page-nav a[href="/"] {
    position: relative;
    display: grid;
    place-content: center;
    padding: 5px;
    border-radius: 100%;
    height: 40px;
    width: 40px;
    padding: 1rem;
    aspect-ratio: 1;
  }
</style>

<style is:global>
  /* The thumb is morphed between pages by the view transition; this tunes
     the browser's default group animation to match the old easing. */
  ::view-transition-group(nav-thumb),
  ::view-transition-image-pair(nav-thumb),
  ::view-transition-old(nav-thumb),
  ::view-transition-new(nav-thumb) {
    animation-duration: 0.4s;
    animation-timing-function: ease-in-out;
  }
</style>
