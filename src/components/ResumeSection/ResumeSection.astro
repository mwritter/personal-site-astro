---
import { render, type CollectionEntry } from "astro:content";
import { date } from "astro:schema";

interface Props {
  section: CollectionEntry<"resume">;
}

const { section } = Astro.props;
const { Content } = await render(section);

const { title, company, startDate, endDate, description, link } = section.data;
let dates = "";
if (startDate) {
  dates += startDate;
  if (endDate) {
    dates = `${dates} - ${endDate}`;
  } else {
    dates = `${dates} - Present`;
  }
}
---

<div class="resume-section">
  <div class="info">
    <h2>{title}</h2>
    <p class="company">{company}</p>
    {dates && <p class="subtext">{dates}</p>}
    {
      link && (
        <a class="subtext" href={link} target="_blank">
          {link}
        </a>
      )
    }
  </div>
  <div class="content">
    <Content />
  </div>
  <hr />
</div>

<style>
  .resume-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  h2 {
    font-size: 16px;
    font-weight: bold;
  }
  .info {
    display: flex;
    flex-direction: column;
  }
  .subtext {
    font-size: 10px;
    opacity: 0.5;
  }
  .company {
    font-size: 12px;
    font-weight: bold;
  }
  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 14px;
  }
  hr {
    border: 1px solid var(--secondary-color);
    border-radius: 10px;
  }
  a {
    white-space: nowrap;
    width: min-content;
  }
</style>
