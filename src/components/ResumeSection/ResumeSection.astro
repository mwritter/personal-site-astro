---
import { render, type CollectionEntry } from "astro:content";
import { endsWith } from "astro:schema";

interface Props {
  section: CollectionEntry<"resume">;
}

const { section } = Astro.props;
const { Content } = await render(section);

const { title, company, startDate, endDate } = section.data;
let dates = `${startDate}`;
if (endDate) {
  dates = `${dates} - ${endDate}`;
}
---

<div class="resume-section">
  <div class="info">
    <h2>{title}</h2>
    <p class="company">{company}</p>
    <p class="subtext">{dates}</p>
  </div>
  <div class="content">
    <Content />
  </div>
  <hr />
</div>

<style>
  .resume-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  h2 {
    font-size: 16px;
    font-weight: bold;
  }
  .info {
    display: flex;
    flex-direction: column;
  }
  .subtext {
    font-size: 10px;
    opacity: 0.5;
  }
  .company {
    font-size: 12px;
    font-weight: bold;
  }
  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 14px;
  }
  hr {
    border: 1px solid var(--secondary-color);
    border-radius: 10px;
  }
</style>
